# Docker / PostgreSQL
POSTGRES_DB=vikunja
POSTGRES_USER=vikunja
POSTGRES_PASSWORD=vikunja_change_me

# Vikunja
VIKUNJA_JWT_SECRET=replace_with_a_long_random_secret
VIKUNJA_PUBLIC_URL=http://localhost:3456/
VIKUNJA_ENABLE_REGISTRATION=false
VIKUNJA_INTERNAL_URL=http://vikunja:3456/api/v1

# Initial admin bootstrap
VIKUNJA_ADMIN_USERNAME=admin
VIKUNJA_ADMIN_EMAIL=admin@example.local
VIKUNJA_ADMIN_PASSWORD=ChangeMe123!
VIKUNJA_API_TOKEN_TITLE=codex-mcp-token

# Runtime token used by the MCP adapter (set by bootstrap script)
VIKUNJA_API_TOKEN=
MCP_URL=http://localhost:8000/mcp

# Bridge worker (optional)
BRIDGE_PROJECT_ID=13
BRIDGE_PROJECT_IDS=
BRIDGE_PROJECT_FILTERS_JSON=
BRIDGE_POLL_INTERVAL=15
BRIDGE_STATE_FILE=/var/lib/vikunja-bridge/state.json
BRIDGE_CONFIRM_TTL_HOURS=24
BRIDGE_CONFIRM_ALLOWED_USERS=
BRIDGE_NOTIFY_COMMAND=
BRIDGE_NOTIFY_TIMEOUT_SECONDS=8
BRIDGE_MODE_FILE=
BRIDGE_SKIP_DONE=true
BRIDGE_ALLOWED_BUCKET_IDS=
BRIDGE_REQUIRED_LABELS=
BRIDGE_ALLOW_MODE_COMMENT_OVERRIDE=false
BRIDGE_PENDING_COMMENTS_FILE=
BRIDGE_PENDING_COMMENTS_MAX=500
BRIDGE_BACKOFF_MIN_SECONDS=5
BRIDGE_BACKOFF_MAX_SECONDS=300
BRIDGE_TRIGGER_FILE=/var/lib/vikunja-bridge/trigger.signal
BRIDGE_TRIGGER_CHECK_SECONDS=1.0
BRIDGE_WEBHOOK_PORT=8090
BRIDGE_WEBHOOK_PATH=/vikunja/webhook
BRIDGE_WEBHOOK_TOKEN=
BRIDGE_WEBHOOK_MAX_BODY_BYTES=1048576
BRIDGE_WEBHOOK_ALLOWED_EVENTS=
BRIDGE_WEBHOOK_ALLOWED_PROJECT_IDS=
BRIDGE_WEBHOOK_REQUIRE_PROJECT_MATCH=false
BRIDGE_WEBHOOK_MONITOR=false
BRIDGE_WEBHOOK_HEALTH_URL=http://localhost:8090/healthz
